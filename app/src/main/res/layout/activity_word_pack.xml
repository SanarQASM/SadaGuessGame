<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_linear_app_background_secondary">

    <!-- AppBar with header -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_linear_app_background_secondary"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/secondary_size_layout">

            <!-- Navigation row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/back_home_activity_button"
                    android:layout_width="@dimen/back_button_size"
                    android:layout_height="@dimen/back_button_size"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/back"
                    android:padding="8dp"
                    android:src="@drawable/ic_back"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/secondary_size_layout"
                    android:fontFamily="@font/primary_font"
                    android:text="@string/word_packs_title"
                    android:textColor="@color/primary_text"
                    android:textSize="@dimen/secondary_size"/>
            </LinearLayout>

            <!-- Subtitle explaining purpose -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginStart="@dimen/big_size_layout"
                android:fontFamily="@font/subtext_font"
                android:text="@string/word_packs_subtitle"
                android:textColor="@color/primary_button_color"
                android:textSize="@dimen/normal_fond_size"/>

            <!-- Built-in cards row (select mode only) -->
            <LinearLayout
                android:id="@+id/rowBuiltInCards"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/secondary_size_layout"
                android:background="@drawable/bg_category_selected"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/secondary_size_layout"
                android:visibility="gone">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/secondary_font"
                    android:text="@string/use_builtin_cards"
                    android:textColor="@color/primary_text"
                    android:textSize="@dimen/sub_font_size"
                    android:textStyle="bold"/>

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@string/use_builtin_cards"
                    android:src="@drawable/ic_back"
                    android:rotation="180"/>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Pack list -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        android:contentDescription="@string/word_count_format"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:id="@+id/packListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/third_size_layout"/>
    </ScrollView>

    <!-- Empty state (centered, overlaid) -->
    <LinearLayout
        android:id="@+id/tvEmptyPacks"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/word_packs_empty_icon"
            android:textSize="56sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/secondary_size_layout"
            android:text="@string/no_word_packs"
            android:textColor="@color/primary_text"
            android:fontFamily="@font/secondary_font"
            android:textSize="@dimen/sub_font_size"
            android:gravity="center"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/primary_size_layout"
            android:text="@string/word_packs_tap_fab_hint"
            android:textColor="@color/primary_button_color"
            android:fontFamily="@font/subtext_font"
            android:textSize="@dimen/normal_fond_size"
            android:gravity="center"/>
    </LinearLayout>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabNewPack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/third_size_layout"
        android:contentDescription="@string/create_word_pack"
        android:text="@string/create_word_pack"
        app:icon="@drawable/ic_add"
        app:backgroundTint="@color/primary_button_color"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>