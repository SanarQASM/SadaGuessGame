<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_linear_app_background_primary"
        android:padding="@dimen/secondary_size_layout">

        <!-- ── Title ── -->
        <TextView
            android:id="@+id/cardsTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/primary_size_layout"
            android:fontFamily="@font/primary_font"
            android:text="@string/cards_page_title"
            android:textColor="@color/primary_text"
            android:textSize="@dimen/primary_size"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <!-- ── Divider ── -->
        <View
            android:id="@+id/div_under_title"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="@color/divider_color"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/cardsTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!--
             ── Card container ──
             FIXED dimensions via card_width / card_height dimens.
             scaleType="centerCrop" ensures image fills without resizing the view.
             The FrameLayout wrapper prevents any constraint re-measurement
             from changing the ShapeableImageView's size.
        -->
        <FrameLayout
            android:id="@+id/cardFrameContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/secondary_size_layout"
            app:layout_constraintTop_toBottomOf="@id/div_under_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:id="@+id/cards"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/button_background"
                android:elevation="20dp"
                android:orientation="vertical"
                android:padding="8dp"
                android:outlineAmbientShadowColor="@color/black"
                android:outlineSpotShadowColor="@color/black"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <!-- FIXED SIZE card image — never changes dimensions -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/cardImage"
                    android:layout_width="@dimen/card_width"
                    android:layout_height="@dimen/card_height"
                    android:layout_margin="10dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/cards"
                    app:shapeAppearanceOverlay="@style/RoundedCard"/>

                <!-- Card name — fixed height so it cannot push card size -->
                <TextView
                    android:id="@+id/cardName"
                    android:layout_width="@dimen/card_width"
                    android:layout_height="@dimen/card_name_height"
                    android:fontFamily="@font/subtext_font"
                    android:text="@string/card_word"
                    android:textColor="@color/primary_color"
                    android:textSize="@dimen/sub_font_size"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="5dp"
                    android:gravity="center"
                    android:ellipsize="end"
                    android:maxLines="1"/>
            </LinearLayout>
        </FrameLayout>

        <!-- ── Tap tip ── -->
        <TextView
            android:id="@+id/warningTip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/subtext_font"
            android:text="@string/txt_tip"
            android:textColor="@color/primary_text"
            android:textSize="@dimen/normal_fond_size"
            android:textStyle="italic"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/cardFrameContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- ── Streak badge ── -->
        <TextView
            android:id="@+id/streakBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="14dp"
            android:paddingVertical="4dp"
            android:background="@drawable/bg_category_selected"
            android:fontFamily="@font/secondary_font"
            android:textColor="@color/primary_text"
            android:textSize="@dimen/sub_font_size"
            android:textStyle="bold"
            android:visibility="gone"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/warningTip"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- ── Group turn ── -->
        <TextView
            android:id="@+id/groupTrun"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/secondary_font"
            android:text="@string/group_turn_A"
            android:textColor="@color/primary_text"
            android:textSize="@dimen/sub_font_size"
            android:textStyle="bold"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/streakBadge"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- ── Hint row ── -->
        <LinearLayout
            android:id="@+id/hintRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/groupTrun"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageButton
                android:id="@+id/hintButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_close"
                android:background="@drawable/bg_category_unselected"
                android:padding="6dp"
                android:contentDescription="@string/hint_button_desc"
                android:scaleType="centerInside"/>

            <TextView
                android:id="@+id/hintCountTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2"
                android:textColor="@color/primary_text"
                android:fontFamily="@font/subtext_font"
                android:textSize="@dimen/sub_font_size"
                android:textStyle="bold"
                android:layout_marginStart="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hint_button_desc"
                android:textColor="@color/primary_text"
                android:fontFamily="@font/subtext_font"
                android:textSize="@dimen/normal_fond_size"
                android:layout_marginStart="4dp"/>
        </LinearLayout>

        <!-- ── Timer circle ── -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/timerContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="5dp"
            android:layout_marginTop="@dimen/secondary_size_layout"
            app:layout_constraintTop_toBottomOf="@id/hintRow"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/colorButtonsContainer">

            <ProgressBar
                android:id="@+id/circularProgressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="@dimen/game_icon_width"
                android:layout_height="@dimen/game_icon_width"
                android:indeterminate="false"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/circular_progress"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <TextView
                android:id="@+id/timeDisplay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/buttons_font"
                android:textDirection="ltr"
                android:padding="5dp"
                android:text="@string/timer_default_display"
                android:textColor="@color/primary_text"
                android:textSize="@dimen/buttons_size"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/secondary_font"
                android:text="@string/timer_tip"
                android:textColor="@color/primary_text"
                android:textSize="@dimen/normal_fond_size"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/circularProgressBar"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_margin="8dp"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ── Control buttons column ── -->
        <LinearLayout
            android:id="@+id/colorButtonsContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="@dimen/secondary_size_layout"
            app:layout_constraintTop_toBottomOf="@id/hintRow"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/startTimer"
                style="@style/PrimaryButtonStyle"
                android:text="@string/txt_start"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/stopTimer"
                style="@style/PrimaryButtonStyle"
                android:layout_marginTop="5dp"
                android:text="@string/txt_stop"/>

            <!--
                RESTART TIMER: resets the countdown only.
                Does NOT change the card.
            -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/restartTimer"
                style="@style/PrimaryButtonStyle"
                android:layout_marginTop="5dp"
                android:text="@string/txt_restart_timer"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/endTimer"
                style="@style/PrimaryButtonStyle"
                android:layout_marginTop="5dp"
                android:text="@string/txt_end"/>

            <!--
                CHANGE CARD: loads a new card.
                Does NOT touch the timer.
            -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/changeCardButton"
                style="@style/PrimaryButtonStyle"
                android:layout_marginTop="5dp"
                android:text="@string/txt_change_card"/>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>