<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="@dimen/secondary_size_layout"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_category_unselected"
    android:gravity="center_vertical">

    <!-- Pack info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvPackName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="My Pack"
            android:textColor="@color/primary_text"
            android:textSize="@dimen/buttons_size"
            android:textStyle="bold"
            android:fontFamily="@font/secondary_font"/>

        <TextView
            android:id="@+id/tvPackSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10 words · Custom"
            android:textColor="@color/primary_text"
            android:textSize="@dimen/normal_fond_size"
            android:fontFamily="@font/subtext_font"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- Action icons -->
    <ImageView
        android:id="@+id/btnSharePack"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_close"
        android:contentDescription="@string/share_pack_title"
        android:padding="4dp"
        android:layout_marginStart="8dp"/>

    <ImageView
        android:id="@+id/btnEditPack"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_back"
        android:contentDescription="@string/edit_word_pack"
        android:padding="4dp"
        android:layout_marginStart="8dp"/>

    <ImageView
        android:id="@+id/btnDeletePack"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/delete"
        android:contentDescription="@string/delete"
        android:padding="4dp"
        android:layout_marginStart="8dp"/>

</LinearLayout>