<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="5dp"
    android:background="@drawable/bg_linear_app_background_primary">

    <!-- Title -->
    <TextView
        android:id="@+id/gameTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/game_score"
        android:fontFamily="@font/primary_font"
        android:textColor="@color/primary_text"
        android:textSize="@dimen/primary_size"
        android:textStyle="bold"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <ScrollView
        android:id="@+id/scrollLayoutScores"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="scroll"
        android:fillViewport="true"
        android:layout_marginTop="60dp"
        android:layout_marginBottom="@dimen/very_big_size_layout"
        app:layout_constraintTop_toBottomOf="@id/gameTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <TableLayout
            android:id="@+id/tableLayoutScores"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/secondary_size_layout"
            android:stretchColumns="*">

            <!-- Header Row -->
            <TableRow
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/secondary_size_layout">

                <!-- Round Header -->
                <TextView
                    android:id="@+id/round"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginTop="@dimen/primary_size_layout"
                    android:fontFamily="@font/normal_text"
                    android:rotation="-45"
                    android:text="@string/round"
                    android:textColor="@color/primary_text"
                    android:textSize="@dimen/sub_font_size"
                    android:textStyle="bold"
                    android:padding="@dimen/primary_size_layout"
                    android:layout_margin="@dimen/primary_size_layout"
                    android:gravity="center"/>

                <!-- Group A Score Header -->
                <TextView
                    android:id="@+id/groupAName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/subtext_font"
                    android:text="@string/txt_group_name"
                    android:textColor="@color/primary_text"
                    android:textSize="@dimen/sub_font_size"
                    android:textStyle="bold"
                    android:padding="@dimen/primary_size_layout"
                    android:layout_margin="@dimen/primary_size_layout"
                    android:layout_marginTop="@dimen/primary_size_layout"
                    android:gravity="center"/>

                <!-- Group B Score Header -->
                <TextView
                    android:id="@+id/groupBName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/subtext_font"
                    android:text="@string/txt_group_name"
                    android:textColor="@color/primary_text"
                    android:textSize="@dimen/sub_font_size"
                    android:textStyle="bold"
                    android:padding="@dimen/primary_size_layout"
                    android:layout_margin="@dimen/primary_size_layout"
                    android:layout_marginTop="@dimen/primary_size_layout"
                    android:gravity="center"/>
            </TableRow>

            <!-- Dynamic rows will be added here from Java -->

        </TableLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/colorButtonsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/scrollLayoutScores"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginTop="@dimen/primary_size_layout"
        android:layout_marginBottom="@dimen/fifth_size_layout">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnContinueGame"
        style="@style/PrimaryButtonStyle"
        android:text="@string/txt_continue_game"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnEndGame"
        style="@style/PrimaryButtonStyle"
        android:layout_marginStart="@dimen/secondary_size_layout"
        android:text="@string/txt_end_game"
        app:layout_constraintTop_toBottomOf="@id/startTimer"
        app:layout_constraintStart_toStartOf="parent" />

    </LinearLayout>




</androidx.constraintlayout.widget.ConstraintLayout>
