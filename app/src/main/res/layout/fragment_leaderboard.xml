<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Title -->
    <TextView
        android:id="@+id/tvLeaderboardTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/primary_font"
        android:text="@string/leaderboard_title"
        android:textColor="@color/primary_text"
        android:textSize="@dimen/primary_size"
        android:layout_marginTop="@dimen/secondary_size_layout"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Subtitle explaining purpose -->
    <TextView
        android:id="@+id/tvLeaderboardSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/subtext_font"
        android:text="@string/leaderboard_subtitle"
        android:textColor="@color/primary_button_color"
        android:textSize="@dimen/normal_fond_size"
        android:gravity="center"
        android:layout_marginHorizontal="@dimen/third_size_layout"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvLeaderboardTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <View
        android:id="@+id/divLb"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/divider_color"
        android:layout_marginTop="@dimen/secondary_size_layout"
        android:layout_marginHorizontal="@dimen/third_size_layout"
        app:layout_constraintTop_toBottomOf="@id/tvLeaderboardSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Column headers -->
    <LinearLayout
        android:id="@+id/lbHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/secondary_size_layout"
        android:paddingVertical="@dimen/primary_size_layout"
        android:layout_marginTop="4dp"
        android:layout_marginHorizontal="@dimen/secondary_size_layout"
        app:layout_constraintTop_toBottomOf="@id/divLb"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="0.5"
            android:text="#"
            android:textColor="@color/primary_button_color"
            android:textStyle="bold"
            android:fontFamily="@font/buttons_font"
            android:textSize="@dimen/normal_fond_size"
            android:gravity="center"/>

        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="2"
            android:text="@string/leaderboard_col_name"
            android:textColor="@color/primary_button_color"
            android:textStyle="bold"
            android:fontFamily="@font/buttons_font"
            android:textSize="@dimen/normal_fond_size"/>

        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1.5"
            android:text="@string/leaderboard_col_record"
            android:textColor="@color/primary_button_color"
            android:textStyle="bold"
            android:fontFamily="@font/buttons_font"
            android:textSize="@dimen/normal_fond_size"
            android:gravity="center"/>

        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="0.8"
            android:text="@string/leaderboard_col_streak"
            android:textColor="@color/primary_button_color"
            android:textStyle="bold"
            android:fontFamily="@font/buttons_font"
            android:textSize="@dimen/normal_fond_size"
            android:gravity="center"/>

        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="0.8"
            android:text="@string/leaderboard_col_winrate"
            android:textColor="@color/primary_button_color"
            android:textStyle="bold"
            android:fontFamily="@font/buttons_font"
            android:textSize="@dimen/normal_fond_size"
            android:gravity="center"/>
    </LinearLayout>

    <View
        android:id="@+id/divLbHeader"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/divider_color"
        android:layout_marginHorizontal="@dimen/third_size_layout"
        app:layout_constraintTop_toBottomOf="@id/lbHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Scrollable rows -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:contentDescription="@string/category_challenge"
        app:layout_constraintTop_toBottomOf="@id/divLbHeader"
        app:layout_constraintBottom_toTopOf="@id/btnClearLeaderboard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/leaderboardRowContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/secondary_size_layout"/>

    </ScrollView>

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/tvLeaderboardEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/divLbHeader"
        app:layout_constraintBottom_toTopOf="@id/btnClearLeaderboard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/leaderboard_empty_icon"
            android:textSize="48sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/secondary_size_layout"
            android:text="@string/leaderboard_empty"
            android:textColor="@color/primary_text"
            android:fontFamily="@font/secondary_font"
            android:textSize="@dimen/sub_font_size"
            android:gravity="center"/>
    </LinearLayout>

    <!-- Clear button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnClearLeaderboard"
        style="@style/PrimaryButtonStyle"
        android:text="@string/leaderboard_clear_title"
        android:layout_marginBottom="@dimen/big_size_layout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>