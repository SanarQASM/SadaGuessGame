<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- FIXED HEADER SECTION (Won't scroll) -->
    <TextView
        android:id="@+id/setting_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/primary_font"
        android:text="@string/setting_page"
        android:textColor="@color/primary_text"
        android:textSize="@dimen/primary_size"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Divider - FIXED -->
    <View
        android:id="@+id/div_under_title"
        android:layout_width="250dp"
        android:layout_height="2dp"
        android:background="?android:attr/listDivider"
        app:layout_constraintTop_toBottomOf="@id/setting_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="3dp" />

    <!-- Lottie Animation - FIXED -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/settingLottieAnimation"
        android:layout_width="match_parent"
        android:layout_height="@dimen/game_icon_width"
        android:layout_gravity="center"
        android:layout_margin="@dimen/fifth_size_layout"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        app:lottie_rawRes="@raw/setting"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/div_under_title"/>

    <!-- SCROLLABLE CONTENT SECTION -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:layout_marginTop="@dimen/secondary_size_layout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/settingLottieAnimation"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/learnHowToPlayContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layoutDirection="locale"
                android:layout_margin="@dimen/third_size_layout"
                android:gravity="center_vertical"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/how_to_play"
                    android:textColor="@color/primary_text"
                    android:fontFamily="@font/buttons_font"
                    android:textSize="@dimen/buttons_size"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/learnPlay"
                    style="@style/PrimaryButtonStyle"
                    android:layout_width="wrap_content"
                    android:text="@string/learn_button" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:id="@+id/divUnderLearnHowToPlay"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="?android:attr/listDivider"
                app:layout_constraintTop_toBottomOf="@id/learnHowToPlayContainer"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="3dp" />

            <LinearLayout
                android:id="@+id/darkMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_margin="@dimen/third_size_layout"
                android:gravity="center_vertical"
                android:layoutDirection="locale"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/divUnderLearnHowToPlay">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/dark_mode"
                    android:textColor="@color/primary_text"
                    android:fontFamily="@font/buttons_font"
                    android:textSize="@dimen/buttons_size"
                    android:textStyle="bold" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/customSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:fontFamily="@font/secondary_font"
                    android:showText="true"
                    app:trackTint="@color/primary_text"
                    app:thumbTint="@color/secondary_color"
                    android:checked="false" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:id="@+id/divUnderDarkMode"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="?android:attr/listDivider"
                app:layout_constraintTop_toBottomOf="@id/darkMode"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="3dp" />

            <LinearLayout
                android:id="@+id/language"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_margin="@dimen/third_size_layout"
                android:gravity="center_vertical"
                android:layoutDirection="locale"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/divUnderDarkMode">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/language"
                    android:textColor="@color/primary_text"
                    android:fontFamily="@font/buttons_font"
                    android:textSize="@dimen/buttons_size"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/languageSpinner"
                    android:layout_width="@dimen/tool_icon_width"
                    android:layout_height="@dimen/big_size_layout"
                    android:layout_marginStart="15dp"
                    android:background="@drawable/spinner_bg_with_arrow"
                    android:spinnerMode="dropdown"/>

            </LinearLayout>

            <!-- Divider -->
            <View
                android:id="@+id/divUnderLanguage"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="?android:attr/listDivider"
                app:layout_constraintTop_toBottomOf="@id/language"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="3dp" />

            <!-- About Section -->
            <LinearLayout
                android:id="@+id/aboutSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layoutDirection="locale"
                android:layout_margin="@dimen/third_size_layout"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/divUnderLanguage">

                <!-- About Title -->
                <TextView
                    android:id="@+id/aboutTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/about"
                    android:textColor="@color/primary_text"
                    android:fontFamily="@font/buttons_font"
                    android:textSize="@dimen/buttons_size"
                    android:textStyle="bold" />

                <!-- App Name -->
                <TextView
                    android:id="@+id/appName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textColor="@color/primary_text"
                    android:fontFamily="@font/buttons_font"
                    android:textSize="@dimen/buttons_size"
                    android:layout_marginTop="@dimen/primary_size_layout" />

                <!-- Version -->
                <TextView
                    android:id="@+id/appVersion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:layout_gravity="center"
                    android:textColor="@color/primary_button_color"
                    android:fontFamily="@font/secondary_font"
                    android:textSize="@dimen/sub_font_size"
                    android:layout_marginTop="@dimen/primary_size_layout" />

                <!-- Description -->
                <TextView
                    android:id="@+id/appDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/about_app_description"
                    android:textColor="@color/primary_text"
                    android:fontFamily="@font/subtext_font"
                    android:layoutDirection="locale"
                    android:textSize="@dimen/sub_font_size"
                    android:layout_marginTop="@dimen/secondary_size_layout" />

                <!-- Privacy Policy Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/privacyPolicyBtn"
                    style="@style/PrimaryButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="@dimen/secondary_size_layout"
                    android:layout_marginBottom="@dimen/secondary_size_layout"
                    android:text="@string/privacy_policy" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>