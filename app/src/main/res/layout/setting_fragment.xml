<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ── FIXED HEADER ── -->
    <TextView
        android:id="@+id/setting_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/primary_font"
        android:text="@string/setting_page"
        android:textColor="@color/primary_text"
        android:textSize="@dimen/primary_size"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <View
        android:id="@+id/div_under_title"
        android:layout_width="250dp"
        android:layout_height="2dp"
        android:background="?android:attr/listDivider"
        android:layout_marginTop="3dp"
        app:layout_constraintTop_toBottomOf="@id/setting_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/settingLottieAnimation"
        android:layout_width="match_parent"
        android:layout_height="@dimen/game_icon_width"
        android:layout_margin="@dimen/fifth_size_layout"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        app:lottie_rawRes="@raw/setting"
        app:layout_constraintTop_toBottomOf="@id/div_under_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── SCROLLABLE CONTENT ── -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:layout_marginTop="@dimen/secondary_size_layout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/settingLottieAnimation"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── How to play ── -->
            <LinearLayout
                android:id="@+id/learnHowToPlayContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layoutDirection="locale"
                android:layout_margin="@dimen/third_size_layout"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/how_to_play"
                    android:textColor="@color/primary_text"
                    android:fontFamily="@font/buttons_font"
                    android:textSize="@dimen/buttons_size"
                    android:textStyle="bold"/>

                <!-- ✅ FIXED: Added missing layout_height -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/learnPlay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/PrimaryButtonStyle"
                    android:text="@string/learn_button"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider"
                android:layout_marginHorizontal="@dimen/third_size_layout"/>

            <!-- ── Dark mode ── -->
            <LinearLayout
                android:id="@+id/darkMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_margin="@dimen/third_size_layout"
                android:gravity="center_vertical"
                android:layoutDirection="locale">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/dark_mode"
                    android:textColor="@color/primary_text"
                    android:fontFamily="@font/buttons_font"
                    android:textSize="@dimen/buttons_size"
                    android:textStyle="bold"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/customSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:trackTint="@color/primary_text"
                    app:thumbTint="@color/secondary_color"
                    android:checked="false"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider"
                android:layout_marginHorizontal="@dimen/third_size_layout"/>

            <!-- ── Voice clue ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_margin="@dimen/third_size_layout"
                android:gravity="center_vertical"
                android:layoutDirection="locale">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/voice_clue_mode"
                        android:textColor="@color/primary_text"
                        android:fontFamily="@font/buttons_font"
                        android:textSize="@dimen/buttons_size"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/voice_clue_desc"
                        android:textColor="@color/primary_text"
                        android:fontFamily="@font/subtext_font"
                        android:textSize="@dimen/normal_fond_size"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/voiceClueSettingSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:trackTint="@color/primary_text"
                    app:thumbTint="@color/secondary_color"
                    android:checked="false"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider"
                android:layout_marginHorizontal="@dimen/third_size_layout"/>

            <!-- ── Sound theme ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_margin="@dimen/third_size_layout">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sound_theme_title"
                    android:textColor="@color/primary_text"
                    android:fontFamily="@font/buttons_font"
                    android:textSize="@dimen/buttons_size"
                    android:textStyle="bold"/>

                <RadioGroup
                    android:id="@+id/soundThemeGroup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp">

                    <RadioButton
                        android:id="@+id/rbClassic"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sound_theme_classic"
                        android:textColor="@color/primary_text"
                        android:fontFamily="@font/subtext_font"
                        android:textSize="@dimen/sub_font_size"
                        android:checked="true"
                        android:layout_marginEnd="12dp"/>

                    <RadioButton
                        android:id="@+id/rbDabke"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sound_theme_dabke"
                        android:textColor="@color/primary_text"
                        android:fontFamily="@font/subtext_font"
                        android:textSize="@dimen/sub_font_size"
                        android:layout_marginEnd="12dp"/>

                    <RadioButton
                        android:id="@+id/rbSilent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sound_theme_silent"
                        android:textColor="@color/primary_text"
                        android:fontFamily="@font/subtext_font"
                        android:textSize="@dimen/sub_font_size"/>
                </RadioGroup>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider"
                android:layout_marginHorizontal="@dimen/third_size_layout"/>

            <!-- ── Language ── -->
            <LinearLayout
                android:id="@+id/language"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_margin="@dimen/third_size_layout"
                android:gravity="center_vertical"
                android:layoutDirection="locale">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/language"
                    android:textColor="@color/primary_text"
                    android:fontFamily="@font/buttons_font"
                    android:textSize="@dimen/buttons_size"
                    android:textStyle="bold"/>

                <!-- ✅ FIXED: min 48dp width satisfies Material touch target requirement -->
                <Spinner
                    android:id="@+id/languageSpinner"
                    android:layout_width="120dp"
                    android:layout_height="@dimen/min_touch_target"
                    android:layout_marginStart="15dp"
                    android:background="@drawable/spinner_bg_with_arrow"
                    android:spinnerMode="dropdown"
                    android:minWidth="@dimen/min_touch_target"
                    android:padding="4dp"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider"
                android:layout_marginHorizontal="@dimen/third_size_layout"/>

            <!-- ── Word Packs ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_margin="@dimen/third_size_layout"
                android:gravity="center_vertical"
                android:layoutDirection="locale">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/manage_word_packs"
                    android:textColor="@color/primary_text"
                    android:fontFamily="@font/buttons_font"
                    android:textSize="@dimen/buttons_size"
                    android:textStyle="bold"/>

                <!-- ✅ FIXED: Added missing layout_height -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnManageWordPacks"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/PrimaryButtonStyle"
                    android:text="@string/word_packs_title"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider"
                android:layout_marginHorizontal="@dimen/third_size_layout"/>

            <!-- ── About ── -->
            <LinearLayout
                android:id="@+id/aboutSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layoutDirection="locale"
                android:layout_margin="@dimen/third_size_layout">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/about"
                    android:textColor="@color/primary_text"
                    android:fontFamily="@font/buttons_font"
                    android:textSize="@dimen/buttons_size"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textColor="@color/primary_text"
                    android:fontFamily="@font/buttons_font"
                    android:textSize="@dimen/buttons_size"
                    android:layout_marginTop="@dimen/primary_size_layout"/>

                <TextView
                    android:id="@+id/appVersion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:textColor="@color/primary_button_color"
                    android:fontFamily="@font/secondary_font"
                    android:textSize="@dimen/sub_font_size"
                    android:layout_marginTop="@dimen/primary_size_layout"/>

                <TextView
                    android:id="@+id/appDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/about_app_description"
                    android:textColor="@color/primary_text"
                    android:fontFamily="@font/subtext_font"
                    android:layoutDirection="locale"
                    android:textSize="@dimen/sub_font_size"
                    android:layout_marginTop="@dimen/secondary_size_layout"/>

                <!-- ✅ FIXED: Added missing layout_height -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/privacyPolicyBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/PrimaryButtonStyle"
                    android:layout_gravity="center"
                    android:layout_marginTop="@dimen/secondary_size_layout"
                    android:layout_marginBottom="@dimen/secondary_size_layout"
                    android:text="@string/privacy_policy"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>