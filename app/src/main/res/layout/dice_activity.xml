<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_linear_app_background_primary">

    <androidx.cardview.widget.CardView
        android:id="@+id/winnerCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        app:cardCornerRadius="32dp"
        app:cardElevation="12dp"
        android:clipToPadding="false"
        android:clipChildren="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_linear_app_background_secondary">

            <!-- FIXED HEADER -->
            <LinearLayout
                android:id="@+id/logo_name_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="start|center"
                android:paddingStart="10dp"
                android:paddingTop="5dp"
                android:paddingEnd="10dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageView
                    android:id="@+id/back_home_activity_button"
                    android:layout_width="@dimen/back_button_size"
                    android:layout_height="@dimen/back_button_size"
                    android:contentDescription="@string/home_page"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="8dp"
                    android:src="@drawable/ic_back"/>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:layout_marginHorizontal="12dp"
                    android:background="?android:attr/listDivider"/>

                <com.google.android.material.imageview.ShapeableImageView
                    android:layout_width="@dimen/image_size"
                    android:layout_height="@dimen/image_size"
                    android:layout_margin="10dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/sada_guess_main_image"
                    app:shapeAppearanceOverlay="@style/CircleImage"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:layout_marginStart="@dimen/secondary_size_layout"
                    android:gravity="start|center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/primary_font"
                        android:text="@string/application_name"
                        android:textColor="@color/primary_text"
                        android:textSize="@dimen/primary_size"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/buttons_font"
                        android:text="@string/dice_title"
                        android:textColor="@color/primary_text"
                        android:textSize="@dimen/sub_font_size"/>
                </LinearLayout>
            </LinearLayout>

            <!-- SCROLLABLE CONTENT -->
            <ScrollView
                android:id="@+id/scrollView"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:fillViewport="true"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/logo_name_container"
                app:layout_constraintBottom_toBottomOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="@dimen/big_size_layout">

                    <!-- Dice count title -->
                    <TextView
                        android:id="@+id/selectDice"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="16dp"
                        android:fontFamily="@font/secondary_font"
                        android:text="@string/txt_select_dice"
                        android:textColor="@color/primary_text"
                        android:textSize="@dimen/buttons_size"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>

                    <!-- 1 or 2 dice selector -->
                    <LinearLayout
                        android:id="@+id/colorButtonsContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/primary_size_layout"
                        android:orientation="horizontal"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/selectDice">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn1Dice"
                            style="@style/PrimaryButtonStyle"
                            android:text="@string/dice1"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn2Dice"
                            style="@style/PrimaryButtonStyle"
                            android:layout_marginStart="@dimen/secondary_size_layout"
                            android:text="@string/dice2"/>
                    </LinearLayout>

                    <!-- Double probability label -->
                    <TextView
                        android:id="@+id/probability_double"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/secondary_font"
                        android:text="@string/probability_double"
                        android:textColor="@color/primary_text"
                        android:layout_marginTop="@dimen/third_size_layout"
                        android:textSize="@dimen/sub_font_size"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/colorButtonsContainer"/>

                    <!-- Probability buttons -->
                    <LinearLayout
                        android:id="@+id/btn_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/secondary_size_layout"
                        android:orientation="horizontal"
                        android:padding="10dp"
                        android:gravity="center"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/probability_double">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn0"
                            style="@style/SmallButtonStyle"
                            android:layout_width="56dp"
                            android:text="@string/prob_0"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_1"
                            style="@style/SmallButtonStyle"
                            android:layout_width="56dp"
                            android:layout_marginStart="12dp"
                            android:text="@string/prob_25"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_2"
                            style="@style/SmallButtonStyle"
                            android:layout_width="56dp"
                            android:layout_marginStart="12dp"
                            android:text="@string/prob_50"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_3"
                            style="@style/SmallButtonStyle"
                            android:layout_width="56dp"
                            android:layout_marginStart="12dp"
                            android:text="@string/prob_75"/>
                    </LinearLayout>

                    <!-- Dice display area — FIXED SIZE container -->
                    <FrameLayout
                        android:id="@+id/diceContainer"
                        android:layout_width="@dimen/image_get_started_size"
                        android:layout_height="@dimen/image_get_started_size"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="@dimen/fourth_size_layout"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/btn_container">

                        <LinearLayout
                            android:id="@+id/dicesContainer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:visibility="gone"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/dices1Image"
                                android:layout_width="@dimen/tool_icon_higth"
                                android:layout_height="@dimen/tool_icon_higth"
                                android:contentDescription="@string/dice_title"
                                android:scaleType="centerInside"
                                android:layout_gravity="center"
                                android:src="@drawable/dice1"/>

                            <ImageView
                                android:id="@+id/dices2Image"
                                android:layout_width="@dimen/tool_icon_higth"
                                android:layout_height="@dimen/tool_icon_higth"
                                android:contentDescription="@string/dice_title"
                                android:scaleType="centerInside"
                                android:layout_gravity="center"
                                android:src="@drawable/dice1"/>
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/diceImage"
                            android:layout_width="@dimen/game_icon_width"
                            android:layout_height="@dimen/game_icon_width"
                            android:contentDescription="@string/dice_title"
                            android:scaleType="centerInside"
                            android:layout_gravity="center"
                            android:src="@drawable/dice1"
                            android:visibility="visible"/>

                        <com.airbnb.lottie.LottieAnimationView
                            android:id="@+id/diceLottie"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_gravity="center"
                            app:lottie_rawRes="@raw/dice"
                            app:lottie_loop="true"
                            android:visibility="gone"/>
                    </FrameLayout>

                    <!-- Result text — shows roll outcome clearly -->
                    <TextView
                        android:id="@+id/tvDiceResult"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/primary_font"
                        android:textColor="@color/primary_button_color"
                        android:textSize="@dimen/secondary_size"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginTop="@dimen/primary_size_layout"
                        android:visibility="gone"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/diceContainer"/>

                    <!-- Skip animation -->
                    <CheckBox
                        android:id="@+id/checkboxSkipAnimation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/skip_animation"
                        android:layout_marginEnd="@dimen/third_size_layout"
                        android:layout_marginTop="@dimen/secondary_size_layout"
                        android:fontFamily="@font/subtext_font"
                        android:textColor="@color/primary_text"
                        android:textSize="@dimen/sub_font_size"
                        android:checked="false"
                        app:layout_constraintTop_toBottomOf="@+id/tvDiceResult"
                        app:layout_constraintEnd_toEndOf="parent"/>

                    <!-- Roll button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/startRollDice"
                        style="@style/PrimaryButtonStyle"
                        android:layout_marginTop="@dimen/secondary_size_layout"
                        android:layout_marginBottom="@dimen/secondary_size_layout"
                        android:text="@string/start_roll_dice"
                        android:layout_width="wrap_content"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/checkboxSkipAnimation"/>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </ScrollView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>