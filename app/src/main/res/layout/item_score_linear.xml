<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="@dimen/secondary_size_layout"
    android:layout_marginTop="@dimen/secondary_size_layout"
    android:background="@android:color/transparent">

    <!-- Number -->
    <TextView
        android:id="@+id/tvIndex"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1 -"
        android:fontFamily="@font/primary_font"
        android:textColor="@color/primary_text"
        android:textStyle="italic"
        android:textSize="@dimen/buttons_size"/>

    <!-- Group Name -->
    <TextView
        android:id="@+id/tvGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/group_a_color"
        android:fontFamily="@font/secondary_font"
        android:textColor="@color/primary_text"
        android:textStyle="bold"
        android:textSize="@dimen/buttons_size"
        android:layout_marginStart="8dp"/>

    <!-- Group Name -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=" --> "
        android:fontFamily="@font/primary_font"
        android:textColor="@color/primary_text"
        android:textStyle="bold"
        android:textSize="@dimen/buttons_size"
        android:layout_marginStart="@dimen/secondary_size"
        android:layout_marginEnd="@dimen/secondary_size"
        />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/score_added"
        android:fontFamily="@font/subtext_font"
        android:textColor="@color/primary_text"
        android:textStyle="italic"
        android:textSize="@dimen/buttons_size"
        android:layout_marginStart="@dimen/fifth_size_layout"/>


</LinearLayout>
