<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Pack name -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/pack_name_label"
        android:textColor="@color/primary_text"
        android:textSize="@dimen/sub_font_size"
        android:textStyle="bold"/>

    <EditText
        android:id="@+id/etPackName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/pack_name_hint"
        android:inputType="textCapSentences"
        android:maxLength="40"
        android:layout_marginTop="4dp"/>

    <!-- Category -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/pack_category_label"
        android:textColor="@color/primary_text"
        android:textSize="@dimen/sub_font_size"
        android:textStyle="bold"
        android:layout_marginTop="12dp"/>

    <EditText
        android:id="@+id/etPackCategory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/pack_category_hint"
        android:inputType="textCapSentences"
        android:maxLength="30"
        android:layout_marginTop="4dp"/>

    <!-- Words label + count -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/pack_words_label"
            android:textColor="@color/primary_text"
            android:textSize="@dimen/sub_font_size"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvWordCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 words"
            android:textColor="@color/primary_button_color"
            android:textSize="@dimen/normal_fond_size"/>
    </LinearLayout>

    <!-- One word per line -->
    <EditText
        android:id="@+id/etPackWords"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:hint="@string/pack_words_hint"
        android:inputType="textMultiLine|textCapSentences"
        android:gravity="top"
        android:background="@drawable/bg_edit_text_normal"
        android:padding="8dp"
        android:layout_marginTop="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/pack_words_tip"
        android:textColor="@color/primary_button_color"
        android:textSize="@dimen/normal_fond_size"
        android:layout_marginTop="4dp"/>

</LinearLayout>