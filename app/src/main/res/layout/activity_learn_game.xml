<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_linear_app_background_primary">

    <!-- Fixed Header -->
    <LinearLayout
        android:id="@+id/learnHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/secondary_size_layout"
        android:paddingEnd="@dimen/secondary_size_layout"
        android:paddingTop="@dimen/third_size_layout"
        android:paddingBottom="@dimen/secondary_size_layout"
        android:background="@drawable/bg_linear_app_background_secondary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/back_home_activity_button"
            android:layout_width="@dimen/back_button_size"
            android:layout_height="@dimen/back_button_size"
            android:contentDescription="@string/back"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"/>

        <View
            android:layout_width="1dp"
            android:layout_height="32dp"
            android:layout_marginHorizontal="@dimen/secondary_size_layout"
            android:background="?android:attr/listDivider"/>

        <com.google.android.material.imageview.ShapeableImageView
            android:layout_width="@dimen/image_size"
            android:layout_height="@dimen/image_size"
            android:scaleType="centerCrop"
            android:src="@drawable/sada_guess_main_image"
            app:shapeAppearanceOverlay="@style/CircleImage"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/secondary_size_layout"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/primary_font"
                android:text="@string/application_name"
                android:textColor="@color/primary_text"
                android:textSize="@dimen/primary_size"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/buttons_font"
                android:text="@string/learn_game_page_title"
                android:textColor="@color/primary_button_color"
                android:textSize="@dimen/sub_font_size"/>
        </LinearLayout>
    </LinearLayout>

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/learnRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/big_size_layout"
        app:layout_constraintTop_toBottomOf="@id/learnHeader"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>