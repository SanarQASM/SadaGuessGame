<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_linear_app_background_primary">

    <androidx.cardview.widget.CardView
        android:id="@+id/drawCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        app:cardCornerRadius="32dp"
        app:cardElevation="12dp"
        android:clipToPadding="false"
        android:clipChildren="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_linear_app_background_secondary">

                <!-- Draw Animation -->
                <com.airbnb.lottie.LottieAnimationView
                    android:id="@+id/drawAnimation"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/game_icon_width"
                    android:layout_marginTop="24dp"
                    app:lottie_autoPlay="true"
                    app:lottie_loop="true"
                    app:lottie_rawRes="@raw/celebration"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Draw Title -->
                <TextView
                    android:id="@+id/drawTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/draw"
                    android:fontFamily="@font/primary_font"
                    android:textColor="@color/primary_text"
                    android:textSize="@dimen/primary_size"
                    android:textStyle="bold"
                    android:layout_marginTop="@dimen/fourth_size_layout"
                    app:layout_constraintTop_toBottomOf="@id/drawAnimation"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Draw subtitle -->
                <TextView
                    android:id="@+id/drawSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/draw_subtitle"
                    android:fontFamily="@font/secondary_font"
                    android:textColor="@color/primary_button_color"
                    android:textSize="@dimen/buttons_size"
                    android:textStyle="italic"
                    android:layout_marginTop="@dimen/secondary_size_layout"
                    app:layout_constraintTop_toBottomOf="@id/drawTitle"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Handshake / draw icon (Lottie) -->
                <com.airbnb.lottie.LottieAnimationView
                    android:id="@+id/trophyAnimation"
                    android:layout_width="@dimen/game_icon_width"
                    android:layout_height="@dimen/game_icon_width"
                    app:lottie_autoPlay="true"
                    app:lottie_loop="true"
                    app:lottie_rawRes="@raw/trophy"
                    android:layout_marginTop="@dimen/third_size_layout"
                    app:layout_constraintTop_toBottomOf="@id/drawSubtitle"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Score Cards -->
                <LinearLayout
                    android:id="@+id/score_name_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:weightSum="2"
                    android:layout_marginTop="@dimen/third_size_layout"
                    app:layout_constraintTop_toBottomOf="@id/trophyAnimation"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <!-- Group A Card -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="8dp"
                        android:layout_weight="1"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="8dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_linear_app_background_secondary"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:id="@+id/groupOneName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/subtext_font"
                                android:text="@string/txt_group_name"
                                android:textColor="@color/primary_text"
                                android:textSize="@dimen/sub_font_size"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/groupOneScore"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/primary_size_layout"
                                android:text="0"
                                android:textColor="@color/primary_button_color"
                                android:textSize="@dimen/secondary_size"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Group B Card -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="8dp"
                        android:layout_weight="1"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="8dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_linear_app_background_secondary"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:id="@+id/groupTwoName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/subtext_font"
                                android:text="@string/txt_group_name"
                                android:textColor="@color/primary_text"
                                android:textSize="@dimen/sub_font_size"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/groupTwoScore"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/primary_size_layout"
                                android:text="0"
                                android:textColor="@color/primary_button_color"
                                android:textSize="@dimen/secondary_size"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>

                <!-- Action Buttons -->
                <LinearLayout
                    android:id="@+id/colorButtonsContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="@dimen/primary_size_layout"
                    android:layout_marginBottom="@dimen/secondary_size_layout"
                    app:layout_constraintTop_toBottomOf="@id/score_name_container"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnHomePage"
                        style="@style/PrimaryButtonStyle"
                        android:text="@string/txt_home_page" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPlayAgain"
                        style="@style/PrimaryButtonStyle"
                        android:layout_marginStart="@dimen/secondary_size_layout"
                        android:text="@string/txt_play_again" />

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>