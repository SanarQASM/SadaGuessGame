<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_linear_app_background_primary">

    <androidx.cardview.widget.CardView
        android:id="@+id/winnerCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:cardCornerRadius="32dp"
        app:cardElevation="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_linear_app_background_secondary">

                <!-- Celebration + title -->
                <FrameLayout
                    android:id="@+id/congratulationTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <com.airbnb.lottie.LottieAnimationView
                        android:id="@+id/celebrationAnimation"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/game_icon_width"
                        android:layout_gravity="center"
                        app:lottie_autoPlay="true"
                        app:lottie_loop="true"
                        app:lottie_rawRes="@raw/celebration" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="@dimen/big_size_layout"
                        android:fontFamily="@font/primary_font"
                        android:text="@string/winner_title"
                        android:textColor="@color/primary_text"
                        android:textSize="@dimen/secondary_size" />
                </FrameLayout>

                <!-- "Winner is:" -->
                <TextView
                    android:id="@+id/winnerIs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/fourth_size_layout"
                    android:fontFamily="@font/primary_font"
                    android:text="@string/winner_desc"
                    android:textColor="@color/primary_text"
                    android:textSize="@dimen/buttons_size"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/congratulationTitle" />

                <!-- Winner group name -->
                <TextView
                    android:id="@+id/groupWinnerName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:fontFamily="@font/subtext_font"
                    android:text="@string/winner_group_name"
                    android:textColor="@color/primary_text"
                    android:textSize="@dimen/sub_font_size"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.784"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/winnerIs" />

                <!-- Confetti left -->
                <com.airbnb.lottie.LottieAnimationView
                    android:id="@+id/confettiAnimation"
                    android:layout_width="@dimen/game_icon_higth"
                    android:layout_height="@dimen/game_icon_higth"
                    android:layout_gravity="center"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/congratulationTitle"
                    app:layout_constraintVertical_bias="0.0"
                    app:lottie_autoPlay="true"
                    app:lottie_loop="true"
                    app:lottie_rawRes="@raw/confetti" />

                <!-- Trophy -->
                <com.airbnb.lottie.LottieAnimationView
                    android:id="@+id/trophyAnimation"
                    android:layout_width="@dimen/game_icon_width"
                    android:layout_height="@dimen/game_icon_width"
                    android:layout_gravity="center"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.497"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/confettiAnimation"
                    app:lottie_autoPlay="true"
                    app:lottie_loop="true"
                    app:lottie_rawRes="@raw/trophy" />

                <!-- Streak summary (NEW — was missing) -->
                <TextView
                    android:id="@+id/streakSummary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/primary_size_layout"
                    android:fontFamily="@font/subtext_font"
                    android:textColor="@color/primary_text"
                    android:textSize="@dimen/normal_fond_size"
                    android:textStyle="italic"
                    tools:text="🔥 Best streak — A: 3  |  B: 2"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/trophyAnimation" />

                <!-- Score cards -->
                <LinearLayout
                    android:id="@+id/score_name_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:weightSum="2"
                    app:layout_constraintBottom_toTopOf="@+id/colorButtonsContainer"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/streakSummary">

                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="8dp"
                        android:layout_weight="1"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="8dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_linear_app_background_secondary"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:id="@+id/groupOneName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/subtext_font"
                                android:text="@string/txt_group_name"
                                android:textColor="@color/primary_text"
                                android:textSize="@dimen/sub_font_size"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/groupOneScore"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/primary_size_layout"
                                android:text="0"
                                android:textColor="@color/primary_button_color"
                                android:textSize="@dimen/secondary_size"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="8dp"
                        android:layout_weight="1"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="8dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_linear_app_background_secondary"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:id="@+id/groupTwoName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/subtext_font"
                                android:text="@string/txt_group_name"
                                android:textColor="@color/primary_text"
                                android:textSize="@dimen/sub_font_size"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/groupTwoScore"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/primary_size_layout"
                                android:text="0"
                                android:textColor="@color/primary_button_color"
                                android:textSize="@dimen/secondary_size"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- Fireworks -->
                <com.airbnb.lottie.LottieAnimationView
                    android:id="@+id/fireworksAnimation"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/game_icon_higth"
                    android:layout_gravity="center"
                    android:layout_marginBottom="@dimen/secondary_size_layout"
                    app:layout_constraintBottom_toTopOf="@+id/colorButtonsContainer"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/trophyAnimation"
                    app:layout_constraintVertical_bias="1.0"
                    app:lottie_autoPlay="true"
                    app:lottie_loop="true"
                    app:lottie_rawRes="@raw/fireworks" />

                <!-- Action buttons — Home | Play Again | Share (NEW) -->
                <LinearLayout
                    android:id="@+id/colorButtonsContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/secondary_size_layout"
                    android:layout_marginTop="@dimen/primary_size_layout"
                    android:orientation="horizontal"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/fireworksAnimation">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnHomePage"
                        style="@style/PrimaryButtonStyle"
                        android:text="@string/txt_home_page" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPlayAgain"
                        style="@style/PrimaryButtonStyle"
                        android:layout_marginStart="@dimen/secondary_size_layout"
                        android:text="@string/txt_play_again" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnShareWinner"
                        style="@style/PrimaryButtonStyle"
                        android:layout_marginStart="@dimen/secondary_size_layout"
                        android:text="@string/share_result"
                        app:icon="@drawable/ic_share" />

                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>