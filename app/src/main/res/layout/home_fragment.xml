<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Header -->
        <LinearLayout
            android:id="@+id/logo_name_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:paddingTop="@dimen/third_size_layout"
            android:paddingEnd="10dp"
            android:layoutDirection="locale"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.imageview.ShapeableImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_margin="10dp"
                android:elevation="20dp"
                android:outlineAmbientShadowColor="@color/black"
                android:outlineSpotShadowColor="@color/black"
                android:scaleType="centerCrop"
                android:src="@drawable/sada_guess_main_image"
                app:shapeAppearanceOverlay="@style/CircleImage" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:fontFamily="@font/primary_font"
                android:text="@string/application_name"
                android:textColor="@color/primary_text"
                android:textSize="@dimen/primary_size" />
        </LinearLayout>

        <!-- TextSwitcher -->
        <TextSwitcher
            android:id="@+id/home_text_switcher"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            app:layout_constraintTop_toBottomOf="@id/logo_name_container"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Game Containers -->
        <LinearLayout
            android:id="@+id/liContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layoutDirection="locale"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@+id/home_text_switcher"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <!-- New Game -->
            <LinearLayout
                android:id="@+id/NewGameContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:background="@drawable/bg_category_unselected"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="10dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="@dimen/game_icon_width"
                    android:layout_height="@dimen/game_icon_higth"
                    app:cardCornerRadius="10dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/new_game"
                        android:scaleType="centerCrop"
                        android:src="@drawable/create_new_game" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/subtext_font"
                    android:gravity="center"
                    android:paddingTop="5dp"
                    android:text="@string/new_game"
                    android:textColor="@color/secondary_color"
                    android:textSize="@dimen/sub_font_size"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Continue Game -->
            <LinearLayout
                android:id="@+id/ContinueGameContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:background="@drawable/bg_category_unselected"
                android:clickable="false"
                android:enabled="false"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="10dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="@dimen/game_icon_width"
                    android:layout_height="@dimen/game_icon_higth"
                    app:cardCornerRadius="10dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/continue_game"
                        android:scaleType="centerCrop"
                        android:src="@drawable/continue_prev_game" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/subtext_font"
                    android:gravity="center"
                    android:paddingTop="5dp"
                    android:text="@string/continue_game"
                    android:textColor="@color/secondary_color"
                    android:textSize="@dimen/sub_font_size"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Learn How to Play -->
        <LinearLayout
            android:id="@+id/learnHowToPlayContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layoutDirection="locale"
            android:paddingStart="@dimen/third_size_layout"
            android:paddingEnd="@dimen/third_size_layout"
            android:layout_marginTop="20dp"
            android:layout_alignParentEnd="true"
            app:layout_constraintTop_toBottomOf="@id/liContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/learn_game"
                android:textColor="@color/primary_text"
                android:fontFamily="@font/secondary_font"
                android:textSize="@dimen/sub_font_size"
                android:textStyle="bold"
                android:gravity="start|center_vertical"
                android:layout_gravity="center_vertical"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/learnPlay"
                style="@style/PrimaryButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:text="@string/learn_button" />
        </LinearLayout>

        <!-- Tools Section -->
        <LinearLayout
            android:id="@+id/toolsContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layoutDirection="locale"
            android:layout_marginTop="20dp"
            android:layout_marginStart="20dp"
            app:layout_constraintTop_toBottomOf="@id/learnHowToPlayContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tools"
                android:textColor="@color/primary_text"
                android:fontFamily="@font/secondary_font"
                android:textSize="@dimen/secondary_size"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:text="@string/tool_disc"
                android:fontFamily="@font/secondary_font"
                android:textColor="@color/primary_text"
                android:textSize="@dimen/sub_font_size"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:id="@+id/divUnderTools"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:background="?android:attr/listDivider"
            android:layout_marginTop="3dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            app:layout_constraintTop_toBottomOf="@id/toolsContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Timer / Dice / Score Section -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layoutDirection="locale"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/divUnderTools"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Timer -->
            <LinearLayout
                android:id="@+id/Timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="10dp"
                android:layout_margin="5dp"
                android:background="@drawable/bg_category_unselected">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="@dimen/tool_icon_width"
                    android:layout_height="@dimen/tool_icon_higth"
                    app:cardCornerRadius="10dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/txt_timer"
                        android:src="@drawable/timer"
                        android:scaleType="centerCrop"/>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_timer"
                    android:gravity="center"
                    android:textSize="@dimen/sub_font_size"
                    android:fontFamily="@font/subtext_font"
                    android:textColor="@color/secondary_color"
                    android:textStyle="bold"
                    android:paddingTop="2dp"/>
            </LinearLayout>

            <!-- Dice -->
            <LinearLayout
                android:id="@+id/DiceContiner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="10dp"
                android:layout_margin="5dp"
                android:background="@drawable/bg_category_unselected">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="@dimen/tool_icon_width"
                    android:layout_height="@dimen/tool_icon_higth"
                    app:cardCornerRadius="10dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/txt_Dice"
                        android:src="@drawable/dice"
                        android:scaleType="centerCrop"/>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_Dice"
                    android:gravity="center"
                    android:textSize="@dimen/sub_font_size"
                    android:fontFamily="@font/subtext_font"
                    android:textColor="@color/secondary_color"
                    android:textStyle="bold"
                    android:paddingTop="2dp"/>
            </LinearLayout>

            <!-- Score -->
            <LinearLayout
                android:id="@+id/scoreBoardContiner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="10dp"
                android:layout_margin="5dp"
                android:background="@drawable/bg_category_unselected">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="@dimen/tool_icon_width"
                    android:layout_height="@dimen/tool_icon_higth"
                    app:cardCornerRadius="10dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/txt_Score"
                        android:src="@drawable/score"
                        android:scaleType="centerCrop"/>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_Score"
                    android:gravity="center"
                    android:textSize="@dimen/sub_font_size"
                    android:fontFamily="@font/subtext_font"
                    android:textColor="@color/secondary_color"
                    android:textStyle="bold"
                    android:paddingTop="2dp"/>
            </LinearLayout>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>