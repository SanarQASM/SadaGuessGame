    <!-- ── Learn how to play ── -->
    <string name="learn_game_page_title">چەوانیا یاریێ</string>
    <string name="learn_section_overview_title">سەدە گێس چی یە؟</string>
    <string name="learn_section_overview_desc">سەدە گێس یاریەکا ب کۆمەڵە. دبنە دوو تیم، نۆرە نۆرە کارتەکی هەلدگرن و دێ وێ پەیڤێ نیشان دەن یان وەسف کەن — بێی کو ناڤێ وێ بێژن! تێما پتر پەیڤان مەزندە بکەت دێ بەت.</string>
    <string name="learn_section_new_game_title">دەستپێکرنا یاریەکا نوی</string>
    <string name="learn_section_new_game_desc">ل بەرپەرێ سەرەکی "یارییا نوی" هەلبژێرە. ناڤێن تیمان بنڤیسە، جۆر و خولان و ئاستێ زەحمەتیێ و دەمی ڕێکبخە. پاشان دەست بنێ ل سەر "دەستپێکرنا یاریێ".</string>
    <string name="learn_section_cards_title">بەرپەرێ کارتێ</string>
    <string name="learn_section_cards_desc">دەست ل سەر کارتێ بدە دا پەیڤ دیار بیت. تێما کارا دێ پەیڤێ ڕوون کەت دەمێ کات دچیت. بۆ پەیڤەکا نوی بێی سفرکرنا دەمی، "کارتا نوی" هەلبژێرە.</string>
    <string name="learn_section_scoring_title">نمرەدان</string>
    <string name="learn_section_scoring_desc">دەمێ کات تەمام دبیت، دێ پسیار کەت کا کارت هاتە دیتن یان نە. ئەگەر بەڵێ بیت نمرەکێ بدێ. ئەگەر پەیڤ ل دویڤ ئێک هاتنە دیتن دێ نمرە دوو جاران زێدە بن!</string>
    <string name="learn_section_timer_title">ئامرازا کاتژمێرێ</string>
    <string name="learn_section_timer_desc">دشێی کاتژمێرێ ب تنێ بەکاربینی. خۆلەک و چرکەیان دیار بکە و دەستپێبکە.</string>
    <string name="learn_section_dice_title">ئامرازا زاری</string>
    <string name="learn_section_dice_desc">١ یان ٢ زاران بهاڤێژە. دشێی ئەگەرێ جووت بوونێ ژی ڕێکبێخی.</string>
    <string name="learn_section_scoreboard_title">تەختێ نمران</string>
    <string name="learn_section_scoreboard_desc">نمرێن هەر یاریەکێ تۆمار بکە. دشێی ناڤ و ڕەنگێن تیمان بگۆڕی.</string>
    <string name="learn_section_wordpacks_title">پاکێتێن پەیڤان</string>
    <string name="learn_section_wordpacks_desc">پاکێتێن تایبەت ب پەیڤێن خۆ چێکە! ب ڕێکا ڕێکخستنان دشێی وان بەڕێڤەبەری.</string>
    <string name="learn_section_difficulty_title">ئاستێن زەحمەتیێ</string>
    <string name="learn_section_difficulty_desc">ئاستێ بۆسا، ناڤنجی یان ب زەحمەت هەلبژێرە. ئەڤە دێ کار کەتە سەر پەیڤێن دهێنە نیشاندان.</string>
    <string name="learn_section_streak_title">زنجیرە و کۆمبۆ</string>
    <string name="learn_section_streak_desc">دیتنا پەیڤان ل دویڤ ئێک دێ زنجیرەکێ (Streak) دروست کەت و نمرێن تە زێدەتر کەت.</string>
    <string name="learn_section_hints_title">هاریکاری</string>
    <string name="learn_section_hints_desc">هەر تیمەک ژمارەکا هاریکاریان یا هەی. دشێی دەست بنێ ل سەر دوگمێ هاریکاریێ دا پیتێن پەیڤێ ببینی.</string>
    <string name="learn_section_leaderboard_title">ڕێزبەندی</string>
    <string name="leaderboard_empty">هێشتا چ یاری نینن.\nیاریا خۆ یا ئێکێ بکە دا ناڤێ تە ل ڤێرێ بهێت!</string>
    <string name="learn_section_voice_title">مودێ ئاماژەیا دەنگی</string>
    <string name="learn_section_voice_desc">کاتێ کارت دیار دبیت، بەرنامە دێ پەیڤێ ب دەنگ خوینیت.</string>
    <string name="learn_section_sudden_death_title">مەرگا ژ نیشکەکێ ڤە</string>
    <string name="learn_section_sudden_death_desc">ئەگەر تیم وەکهەڤ بن، مەرگا ژ نیشکەکێ ڤە دەستپێدکەت. هەر تیمەک ٣٠ چرکە بۆ دیتنا ئێک کارت یا هەی.</string>

