    <!-- ── Learn how to play ── -->
    <string name="learn_game_page_title">چۆنیەتی یاری کردن</string>
    <string name="learn_section_overview_title">Sada Guess چییە؟</string>
    <string name="learn_section_overview_desc">سەدە گێس یارییەکی بەکۆمەڵە. بەسەر دوو تیمدا دابەش دەبن، نۆرە دەگرن لە هەڵگرتنی کارت، و وشەکە دەنوێنن یان وەسفی دەکەن — بێ ئەوەی وشەکە خۆی بڵێن! ئەو تیمەی زۆرترین وشە مەزندە بکات دەباتەوە.</string>
    <string name="learn_section_new_game_title">دەستپێکردنی یاری نوێ</string>
    <string name="learn_section_new_game_desc">لە پەڕەی سەرەکی دەست بنێ بە "یاری نوێ". ناوی تیمەکان بنووسە، جۆری وشەکان دیاری بکە، ژمارەی خولەکان و ئاستی یاری و کاتەکە ڕێکبخە. پاشان دەست بنێ بە "دەستپێکردنی یاری".</string>
    <string name="learn_section_cards_title">پەڕەی کارتەکان</string>
    <string name="learn_section_cards_desc">دەست لە کارتەکە بدە بۆ بینینی وشەکە. تیمی کارا دەبێت وشەکە ڕوون بکاتەوە کاتێک کاتەکە دەڕوات. دەست بنێ بە "کارتی نوێ" بۆ بینینی وشەیەکی تر بەبێ سفرکردنەوەی کاتەکە.</string>
    <string name="learn_section_scoring_title">خاڵبەندی</string>
    <string name="learn_section_scoring_desc">کاتێک کات تەواو دەبێت، پرسیارت لێ دەکرێت ئەگەر تیمەکە وشەکەی دۆزیبێتەوە. ئەگەر بەڵێ بوو خاڵەکە دیاری بکە. ئەگەر بەدوای یەکدا وشەکان بدۆزنەوە خاڵەکان دووقات دەبن!</string>
    <string name="learn_section_timer_title">ئامرازی کاتژمێر</string>
    <string name="learn_section_timer_desc">دەتوانیت کاتژمێری سەربەخۆ بەکاربهێنیت. خولەک و چرکە دیاری بکە و دەست پێ بکە.</string>
    <string name="learn_section_dice_title">ئامرازی زار</string>
    <string name="learn_section_dice_desc">١ یان ٢ زار هەڵبدە. دەتوانیت ئەگەری جوت بوون ڕێکبخەیت.</string>
    <string name="learn_section_scoreboard_title">تەختەی خاڵەکان</string>
    <string name="learn_section_scoreboard_desc">بۆ هەر یارییەک خاڵەکان تۆمار بکە. دەتوانیت ناوی تیم و ڕەنگیان بگۆڕیت.</string>
    <string name="learn_section_wordpacks_title">پاکێجی وشەکان</string>
    <string name="learn_section_wordpacks_desc">پاکێجی تایبەت بە وشەکانی خۆت دروست بکە! لە ڕێگەی ڕێکخستنەکانەوە دەتوانیت بەڕێوەیان ببەیت.</string>
    <string name="learn_section_difficulty_title">ئاستەکانی یاری</string>
    <string name="learn_section_difficulty_desc">ئاستی ئاسان، مامناوەند یان سەخت هەڵبژێرە. ئاستەکە کاردەکاتە سەر جۆری ئەو وشانەی پیشان دەدرێن.</string>
    <string name="learn_section_streak_title">زنجیرە و کۆمبۆ</string>
    <string name="learn_section_streak_desc">دۆزینەوەی وشەکان بەدوای یەکدا زنجیرە (Streak) دروست دەکات و خاڵەکانت زیاد دەکات.</string>
    <string name="learn_section_hints_title">هاوکارییەکان</string>
    <string name="learn_section_hints_desc">هەر تیمێک ژمارەیەک هاوکاری هەیە. دەتوانیت دەست بنێیت بە دوگمەی هاوکاری بۆ بینینی پیتەکانی وشەکە.</string>
    <string name="learn_section_leaderboard_title">ڕیزبەندی</string>
    <string name="learn_section_voice_title">دۆخی ئاماژەی دەنگی</string>
    <string name="learn_section_voice_desc">کاتێک کارتەکە دەکرێتەوە، ئامێرەکە وشەکە بە دەنگ دەخوێنێتەوە.</string>
    <string name="learn_section_sudden_death_title">مەرگی لەناکاو</string>
    <string name="learn_section_sudden_death_desc">ئەگەر هەردوو تیم یەکسان بن، مەرگی لەناکاو دەست پێ دەکات. هەر تیمێک ٣٠ چرکەی هەیە بۆ دۆزینەوەی یەک کارت.</string>

