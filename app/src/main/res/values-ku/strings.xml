    <!-- ── Req 1: Learn Game Screen ──────────────────────────────────────── -->
    <string name="learn_game_page_title">چۆنیەتی یاریکردن</string>

    <string name="learn_section_overview_title">SadaGuess چییە؟</string>
    <string name="learn_section_overview_desc">‏SadaGuess یارییەکی کۆمەڵایەتی مەزندەکردنە. دابەش دەبن بۆ دوو تیم، بە نۆرە کارتێک ڕادەکێشن و وشەکە دەنوێنن یان وەسفی دەکەن — بەبێ ئەوەی ناوی وشەکە بڵێن! ئەو تیمەی زۆرترین وشە مەزندە بکات، دەبێتە براوە.</string>

    <string name="learn_section_new_game_title">دەستپێکردنی یارییەکی نوێ</string>
    <string name="learn_section_new_game_desc">لەسەر شاشەی سەرەکی کلیک لەسەر "New Game" بکە. ناوی تیمەکان بنووسە، جۆری وشەکان (Categories) هەڵبژێرە، ژمارەی خولەکان و ئاستی زەحمەتی دیاری بکە، هەروەها کاتی یارییەکە دابنێ. پاشان کلیک لەسەر "Start Game" بکە.</string>

    <string name="learn_section_cards_title">شاشەی کارتەکە</string>
    <string name="learn_section_cards_desc">پەنجە بنێ بە کارتەکەدا بۆ دەرکەوتنی وشەکە. تیمی چالاک دەبێت وشەکە بنوێنێت یان وەسفی بکات پێش ئەوەی کاتەکە تەواو بێت. بۆ گۆڕینی وشەکە بەبێ سفرکردنەوەی کات، کلیک لە "Change Card" بکە. کلیک لە "Restart Timer" بکە تەنها بۆ سفرکردنەوەی کاتژمێرەکە.</string>

    <string name="learn_section_scoring_title">خاڵبەندی</string>
    <string name="learn_section_scoring_desc">کاتێک کات تەواو دەبێت، پرسیارێکت لێ دەکرێت کە ئایا تیمەکە وشەکەی دۆزیوەتەوە؟ "Yes" هەڵبژێرە و خاڵێک دیاری بکە (١-٣ خاڵ). ئەگەر بەدوای یەکدا وشەکان بدۆزنەوە خاڵەکان زیاد دەکەن (Combo): ٣ وشەی ڕاست لەسەریەک = ١.٥ هێندە، ٥ وشە = ٢ هێندە!</string>

    <string name="learn_section_timer_title">ئامرازی کاتژمێر</string>
    <string name="learn_section_timer_desc">دەتوانیت لە شاشەی سەرەکییەوە ئامرازی کاتژمێر (Timer) بەکاربهێنیت. خولەک و چرکەکان دیاری بکە و "Start" دابگرە. کاتێک کات خەریکە تەواو دەبێت، دەنگێکی ئاگادارکردنەوە لێ دەدات.</string>

    <string name="learn_section_dice_title">ئامرازی زار</string>
    <string name="learn_section_dice_desc">لە شاشەی سەرەکی ١ یان ٢ زار هەڵبدە. لە کاتی بەکارهێنانی ٢ زاردا، دەتوانیت ئەگەری جووتبوون (Double) دیاری بکەیت (٢٥٪-٧٥٪). کاتێک زارەکان جووت دەبن، دەنگێکی تایبەت لێ دەدات!</string>

    <string name="learn_section_scoreboard_title">تەختەی ئەنجامەکان</string>
    <string name="learn_section_scoreboard_desc">لەسەر تەختەی ئەنجامەکان (Score Board) خاڵی هەر یارییەک تۆمار بکە. ناوی تیمەکان بگۆڕە، پەنجە بنێ بە پانێڵی تیمەکەدا بۆ زیادکردنی خاڵ، ڕەنگیان هەڵبژێرە، یان مێژووی یارییەکە ببینە.</string>

    <string name="learn_section_wordpacks_title">پاکێجی وشەکان</string>
    <string name="learn_section_wordpacks_desc">پاکێجی تایبەت بە وشەکانی خۆت دروست بکە! بڕۆ بۆ Settings ← Manage Word Packs. دەتوانیت ئەم پاکێجانە لە ڕێگەی نامەوە بۆ هاوڕێکانت بنێریت.</string>

    <string name="learn_section_difficulty_title">ئاستی زەحمەتی</string>
    <string name="learn_section_difficulty_desc">لە کاتی دەستپێکردن ئاستی ئاسان، مامناوەند، یان قورس هەڵبژێرە. ئاستی ئاسان وشەی باو و ناسراون؛ ئاستی قورس وشەی دەگمەن و ئاڵۆزن.</string>

    <string name="learn_section_streak_title">بەدوای یەکدا بوون (Streaks)</string>
    <string name="learn_section_streak_desc">مەزندەکردنی چەند کارتێک بە دروستی و لەسەریەک، خاڵەکانت زیاد دەکات. لە ٣ کارتدا خاڵەکە دەبێتە ١.٥ هێندە، لە ٥ کارتدا دەبێتە ٢ هێندە. هەر هەڵەیەک زنجیرەکە دەپچڕێنێت و خاڵەکان ئاسایی دەبنەوە.</string>

    <string name="learn_section_hints_title">ڕێنمایی (Hints)</string>
    <string name="learn_section_hints_desc">هەر تیمێک ٢ ڕێنمایی هەیە لە هەر یارییەکدا. پێش دەرکەوتنی کارتەکە، پەنجە بنێ بە دوگمەی ڕێنماییدا بۆ بینینی پیتی یەکەمی وشەکە. بە وریایی بەکاریان بهێنە چونکە نوێ نابنەوە!</string>

    <string name="learn_section_leaderboard_title">ڕیزبەندی براوەکان</string>
    <string name="learn_section_leaderboard_desc">لیستی ڕیزبەندی (Leaderboard) سەرکەوتن، دۆڕان، یەکسانبوون، و کۆی گشتی خاڵەکانی هەموو ئەو یارییانە تۆمار دەکات کە لەسەر ئەم ئامێرە ئەنجام دراون.</string>

    <string name="learn_section_voice_title">مۆدی دەنگی وشە</string>
    <string name="learn_section_voice_desc">لەکاتی دروستکردنی یارییەکەدا مۆدی Voice Clue چالاک بکە. کاتێک کارتەکە دەکرێتەوە، ئەپەکە وشەکە بە دەنگ دەخوێنێتەوە. ئەمە یارمەتیدەرە بۆ ئەو یاریزانانەی حەز دەکەن وشەکە ببیستن نەک بیخوێننەوە.</string>

    <string name="learn_section_sudden_death_title">مەرگی لەناکاو (Sudden Death)</string>
    <string name="learn_section_sudden_death_desc">ئەگەر هەردوو تیم بە یەکسانی کۆتایییان پێ هات، قۆناغی Sudden Death دەست پێ دەکات! هەر تیمێک ٣٠ چرکەی هەیە بۆ تەنها یەک کارت. یەکەم تیم کە وشەکە بدۆزێتەوە دەبێتە براوە.</string>

