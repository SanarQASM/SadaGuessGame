    <!-- ── ScoreBoardActivity ───────────────────────────────────────────────── -->
    <!-- History row index label, e.g. "3 -" -->
    <string name="history_item_index_format">%1$d -</string>
    <!-- Zero score displayed after restart / undo reaches bottom -->
    <string name="score_zero">0</string>

    <!-- ── RecentlyFragment ─────────────────────────────────────────────────── -->
    <!-- Unfinished game row label, e.g. "1 - [Continue Game]" -->
    <string name="status_index_continue_format">%1$d - [%2$s]</string>
    <!-- Finished game row label, e.g. "2 - " -->
    <string name="status_index_simple_format">%1$d - </string>

    <!-- ── ScoreDialog ──────────────────────────────────────────────────────── -->
    <!-- Streak badge when streak >= 3, e.g. "🔥 x4 Streak!" -->
    <string name="streak_fire_format">🔥 x%1$d Streak!</string>
    <!-- Streak badge when streak == 2, e.g. "⚡ 2 in a row" -->
    <string name="streak_two_in_row_format">⚡ %1$d in a row</string>

    <!-- ── CardsActivity ────────────────────────────────────────────────────── -->
    <!-- Back-of-card placeholder for custom word pack cards -->
    <string name="card_back_placeholder">?</string>
    <!-- Live streak badge on the card screen, e.g. "🔥 3" -->
    <string name="streak_badge_format">🔥 %1$d</string>
    <!-- Timer display format for minutes and seconds, e.g. "01 : 30" -->
    <string name="time_format_mmss">%1$02d : %2$02d</string>
    <!-- Hint toast text, e.g. "💡 L _ _ _" -->
    <string name="hint_display_format">💡 %1$s _ _ _</string>

    <!-- ── SuddenDeathActivity ──────────────────────────────────────────────── -->
    <!-- Two-digit seconds display, e.g. "08" -->
    <string name="time_format_ss">%1$02d</string>

    <!-- ── GameScoreActivity ────────────────────────────────────────────────── -->
    <!-- Streak summary row icon -->
    <string name="score_table_streak_icon">🔥</string>
    <!-- Per-group best-streak cell in score table, e.g. "Best 4×" -->
    <string name="streak_best_format">Best %1$d×</string>
    <!-- Combo star appended to a score cell, e.g. "3★" -->
    <string name="combo_star_char">★</string>
    <!-- Placeholder shown when a group has no score for a given round -->
    <string name="score_placeholder">--</string>

    <!-- ── ShareManager ──────────────────────────────────────────────────────── -->
    <!-- App name drawn on the share-card bitmap (not translatable) -->
    <string name="share_app_name" translatable="false">SadaGuess</string>
    <!-- "vs" separator drawn between group names on the share bitmap -->
    <string name="share_vs_separator">vs</string>
    <!-- Sudden-death winner line on share card, e.g. "⚡ Sudden Death Winner: Team A" -->
    <string name="share_sudden_death_winner_format">⚡ Sudden Death Winner: %1$s</string>
    <!-- Regular winner line on share card, e.g. "🏆 Winner: Team A" -->
    <string name="share_winner_format">🏆 Winner: %1$s</string>
    <!-- Draw result line on share card -->
    <string name="share_draw_label">🤝 Draw!</string>
    <!-- Streak + rounds line on share card -->
    <string name="share_streak_format">🔥 Best streak A: %1$d   B: %2$d   Rounds: %3$d</string>
    <!-- Hashtag watermark on share card (not translatable) -->
    <string name="share_hashtag_watermark" translatable="false">#SadaGuess</string>
    <!-- System share-sheet chooser title -->
    <string name="share_chooser_title">Share result</string>
    <!-- Plain-text body of the share intent -->
    <string name="share_text_format">🎮 SadaGuess Result\n%1$s: %2$d\n%3$s: %4$d\nRounds: %5$d\n#SadaGuess #Kurdish</string>

    <!-- ── WinnerActivity ────────────────────────────────────────────────────── -->
    <!-- Sudden-death winner label shown in winner screen, e.g. "⚡ Team A" -->
    <string name="winner_sudden_death_format">⚡ %1$s</string>
    <!-- Streak summary line below scores, e.g. "🔥 Best streak — A: 3  |  B: 2" -->
    <string name="streak_summary_format">🔥 Best streak — %1$s: %2$d  |  %3$s: %4$d</string>

    <!-- ── LeaderboardFragment ──────────────────────────────────────────────── -->
    <string name="leaderboard_rank_gold">🥇</string>
    <string name="leaderboard_rank_silver">🥈</string>
    <string name="leaderboard_rank_bronze">🥉</string>
    <!-- W/L/D record cell, e.g. "4W  2L  1D" -->
    <string name="leaderboard_record_format">%1$dW  %2$dL  %3$dD</string>
    <!-- Best-streak cell in leaderboard, e.g. "🔥 5" -->
    <string name="leaderboard_streak_format">🔥 %1$d</string>

    <!-- ── WordPackActivity ──────────────────────────────────────────────────── -->
    <!-- Live word-count label in the create-pack dialog, e.g. "12 words" -->
    <string name="word_count_format">%1$d words</string>

