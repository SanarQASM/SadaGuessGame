<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="primary_button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/primary_color</item>
        <item name="android:textColor">@color/primary_button_color</item>
        <item name="cornerRadius">15dp</item>
        <item name="android:layout_width">@dimen/primary_button_size_length</item>
        <item name="android:layout_height">@dimen/primary_button_size_height</item>
        <item name="android:layout_marginStart">@dimen/very_big_size_layout</item>
        <item name="android:layout_marginEnd">@dimen/very_big_size_layout</item>
        <item name="android:layout_marginTop">@dimen/fifth_size_layout</item>
        <item name="android:layout_marginBottom">@dimen/fifth_size_layout</item>
        <item name="android:layout_gravity">center</item>
    </style>

    <style name="CircleImage">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="RoundedCard">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>

    <style name="PrimaryButtonStyle" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">@dimen/primary_button_size_length</item>
        <item name="android:layout_height">@dimen/primary_button_size_height</item>
        <item name="android:textColor">@color/primary_button_color</item>
        <item name="android:elevation">10dp</item>
        <item name="android:textSize">@dimen/sub_font_size</item>
        <item name="cornerRadius">10dp</item>
        <item name="strokeColor">@color/primary_button_color</item>
        <item name="strokeWidth">2dp</item>
        <item name="backgroundTint">@color/secondary_color</item>
    </style>



    <style name="SecondaryButtonStyle" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/primary_text</item>
        <item name="android:elevation">10dp</item>
        <item name="android:padding">@dimen/secondary_size_layout</item>
        <item name="cornerRadius">@dimen/secondary_size_layout</item>
        <item name="strokeColor">@color/primary_button_color</item>
        <item name="strokeWidth">2dp</item>
        <item name="backgroundTint">@color/primary_color</item>
    </style>

    <style name="SmallButtonStyle" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textColor">@color/primary_text</item>
        <item name="android:elevation">10dp</item>
        <item name="android:padding">@dimen/secondary_size_layout</item>
        <item name="cornerRadius">@dimen/secondary_size_layout</item>
        <item name="android:fontFamily">@font/buttons_font</item>
        <item name="android:textSize">@dimen/sub_font_size</item>
        <item name="strokeColor">@color/primary_button_color</item>
        <item name="strokeWidth">2dp</item>
        <item name="backgroundTint">@color/secondary_color</item>
    </style>

    <style name="BigButtonStyle" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/primary_button_color</item>
        <item name="android:padding">@dimen/secondary_size_layout</item>
        <item name="android:elevation">10dp</item>
        <item name="fontFamily">@font/primary_font</item>
        <item name="android:textSize">@dimen/buttons_size</item>
        <item name="cornerRadius">10dp</item>
        <item name="strokeColor">@color/primary_button_color</item>
        <item name="strokeWidth">3dp</item>
        <item name="backgroundTint">@color/secondary_color</item>
    </style>

    <style name="ButtonWithoutBackground" parent="Widget.MaterialComponents.Button.TextButton">
        <!-- Size -->
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">50dp</item>
        <!-- Text color -->
        <item name="android:textColor">@color/primary_button_color</item>
        <!-- Transparent background -->
        <item name="backgroundTint">@android:color/transparent</item>
    </style>

    <style name="AppEditTextStyle">
        <item name="android:layout_width">@dimen/text_input_lenght</item>
        <item name="android:layout_height">@dimen/primary_button_size_height</item>
        <item name="android:padding">12dp</item>
        <item name="android:textSize">@dimen/sub_font_size</item>
        <item name="android:textColor">@color/primary_text</item>
        <item name="android:fontFamily">@font/subtext_font</item>
        <item name="android:background">@drawable/bg_edit_text_selector</item>
        <item name="android:enabled">true</item>
        <item name="android:focusable">true</item>
        <item name="android:focusableInTouchMode">true</item>
        <item name="android:clickable">true</item>
    </style>







</resources>