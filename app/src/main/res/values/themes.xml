<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Night-mode theme overrides.
        All color values live in values-night/colors.xml.
        No <color> declarations here — that would duplicate them.
    -->
    <style name="Theme.SadaGuessGame" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary_button_color</item>
        <item name="colorPrimaryVariant">@color/primary_color</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/secondary_color</item>
        <item name="colorOnSecondary">@color/primary_text</item>
        <item name="android:windowBackground">@color/primary_color</item>
        <item name="android:textColor">@color/primary_text</item>
        <item name="android:fontFamily">@font/normal_text</item>
        <item name="colorControlHighlight">@color/primary_button_color</item>
    </style>

    <style name="GameDialogTheme" parent="ThemeOverlay.MaterialComponents.Dialog.Alert">
        <item name="colorPrimary">@color/primary_button_color</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="android:textColor">@color/primary_text</item>
    </style>

</resources>