<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.sadaguessgame">

    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.VIBRATE"/>

    <application
        android:name=".MyApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/app_icon"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/app_icon_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SadaGuessGame">

        <!-- ── Existing activities ── -->

        <activity
            android:name="com.example.sadaguessgame.activities.SplashActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|layoutDirection|locale">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <activity
            android:name="com.example.sadaguessgame.ui.GetStarted"
            android:exported="false"
            android:configChanges="orientation|screenSize|layoutDirection|locale"/>

        <activity
            android:name="com.example.sadaguessgame.ui.NavigationActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|layoutDirection|locale"/>

        <activity
            android:name="com.example.sadaguessgame.activities.MainActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|layoutDirection|locale"/>

        <activity
            android:name="com.example.sadaguessgame.activities.CreateNewGameActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|layoutDirection|locale"
            android:windowSoftInputMode="adjustResize"/>

        <activity
            android:name="com.example.sadaguessgame.activities.CardsActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|layoutDirection|locale"/>

        <activity
            android:name="com.example.sadaguessgame.activities.GameScoreActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|layoutDirection|locale"/>

        <activity
            android:name="com.example.sadaguessgame.activities.WinnerActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|layoutDirection|locale"/>

        <activity
            android:name="com.example.sadaguessgame.activities.TimerActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|layoutDirection|locale"/>

        <activity
            android:name="com.example.sadaguessgame.activities.ScoreBoardActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|layoutDirection|locale"/>

        <activity
            android:name="com.example.sadaguessgame.activities.DiceActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|layoutDirection|locale"/>

        <activity
            android:name="com.example.sadaguessgame.activities.PrivacyPolicyActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|layoutDirection|locale"/>

        <!-- ── NEW activities (v2) ── -->

        <activity
            android:name="com.example.sadaguessgame.activities.SuddenDeathActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|layoutDirection|locale"/>

        <activity
            android:name="com.example.sadaguessgame.activities.WordPackActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|layoutDirection|locale"
            android:windowSoftInputMode="adjustResize"/>

        <activity
            android:name="com.example.sadaguessgame.activities.LearnGameActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|layoutDirection|locale"/>

        <activity
            android:name="com.example.sadaguessgame.activities.ScoreBoardHistoryActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|layoutDirection|locale"/>

        <!-- ── FileProvider for sharing summary images ── -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths"/>
        </provider>

        <meta-data
            android:name="preloaded_fonts"
            android:resource="@array/preloaded_fonts"/>

    </application>
</manifest>